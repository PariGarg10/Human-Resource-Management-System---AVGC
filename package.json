{
  "name": "hrms-attendance",
  "version": "1.0.0",
  "description": "AVGC attendance tracking system",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "dev:vite": "cd client/avgc-dashboard && npm run dev:vite",
    "build": "npm run build:dashboard",
    "db:init": "node server/initDb.js",
    "db:reset-super-admin": "node server/scripts/reset-super-admin.js",
    "essl:bridge": "node server/scripts/essl-bridge.js",
    "essl:bridge:ping": "node server/scripts/essl-bridge-ping.js",
    "essl:diagnose": "node server/scripts/essl-diagnose.js",
    "essl:test": "node server/scripts/essl-test.js",
    "essl:sync": "node server/scripts/essl-sync-once.js",
    "postinstall": "node server/scripts/postinstall.js",
    "build:dashboard": "npm run install:dashboard && cd client/avgc-dashboard && npm run build && cd ../.. && node scripts/bundle-portal-css.mjs",
    "install:dashboard": "cd client/avgc-dashboard && npm install --include=dev"
  },
  "keywords": [
    "hrms",
    "attendance",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-zklib": "github:hmshb/node-zklib",
    "nodemailer": "^8.0.8",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pg": "^8.20.0",
    "pg-pool": "^3.10.0",
    "xlsx": "^0.18.5",
    "zklib-js": "^1.3.5"
  }
}
