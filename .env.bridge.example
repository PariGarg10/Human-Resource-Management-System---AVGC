# Office PC only — same Wi‑Fi/LAN as the eSSL device.
# Copy to .env on that PC (or merge with your existing .env).

# --- eSSL device (office LAN) ---
ESSL_ENABLED=true
ESSL_DEVICE_IP=192.168.0.254
ESSL_DEVICE_PORT=4370
ESSL_DEVICE_TIMEOUT_MS=30000
ESSL_SDK=node-zklib
ESSL_COMM_KEY=0
ESSL_TCP_ONLY=true
ESSL_DISABLE_DEVICE=true
ESSL_INPORT=5200
ESSL_POLL_INTERVAL_MS=300000
ESSL_LOOKBACK_DAYS=14
ESSL_DAY_START=09:30
ESSL_DAY_END=23:59

# --- Push to Vercel (must match Vercel environment variables) ---
HRMS_API_URL=https://human-resource-management-system-av.vercel.app
BIOMETRIC_API_KEY=use_same_secret_as_on_vercel
ESSL_BRIDGE_MODE=remote

# DATABASE_URL not needed on office PC in remote mode (Vercel has it).
