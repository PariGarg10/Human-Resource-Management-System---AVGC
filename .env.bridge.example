# Copy to .env on the OFFICE PC (same LAN as ESSL device).
# Do NOT commit this file with real secrets.

# --- Device (office LAN) ---
ESSL_ENABLED=true
ESSL_DEVICE_IP=192.168.0.254
ESSL_DEVICE_PORT=4370
ESSL_DEVICE_TIMEOUT_MS=30000
ESSL_INPORT=4000
ESSL_POLL_INTERVAL_MS=300000
ESSL_LOOKBACK_DAYS=14
ESSL_DAY_START=09:30
ESSL_DAY_END=23:59
# ESSL_PREFER_UDP=true

# --- Push to Render (must match Render env vars) ---
HRMS_API_URL=https://YOUR-SERVICE.onrender.com
BIOMETRIC_API_KEY=use_same_secret_as_on_render
ESSL_BRIDGE_MODE=remote

# Not used in remote bridge mode (Render has DATABASE_URL):
# DATABASE_URL=
