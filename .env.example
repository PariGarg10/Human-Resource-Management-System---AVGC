PORT=3000
JWT_SECRET=change-me
BIOMETRIC_API_KEY=your_super_secret_key

# Required on Vercel (Project → Settings → Environment Variables)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Password reset email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=your-email@gmail.com
FRONTEND_URL=http://localhost:3000

# ESSL/ZKTeco attendance device
# IMPORTANT: Vercel cannot reach office LAN IPs (192.168.x.x). Use essl-bridge on an office PC (see npm run essl:bridge).
ESSL_ENABLED=true
ESSL_DEVICE_IP=192.168.0.254
ESSL_DEVICE_PORT=4370
ESSL_DEVICE_TIMEOUT_MS=5000
ESSL_INPORT=4000
# If TCP connects but sync fails, try: ESSL_PREFER_UDP=true
# ESSL_PREFER_UDP=false
# ESSL_DISABLE_DEVICE=false
# Poll every 5 minutes (300000 ms). Every 2 hours = 7200000
ESSL_POLL_INTERVAL_MS=300000
# How many past days to import on each sync (14 is safe for first run)
ESSL_LOOKBACK_DAYS=14
ESSL_DAY_START=09:30
ESSL_DAY_END=23:59

# Bridge script (office PC → Vercel): same key on bridge .env and Vercel env vars
HRMS_API_URL=https://your-app.vercel.app
# local = write to DATABASE_URL on office PC | remote = push to HRMS_API_URL (use with Vercel)
ESSL_BRIDGE_MODE=remote
