PORT=3000
JWT_SECRET=change-me
BIOMETRIC_API_KEY=your_super_secret_key

# Required in production (Vercel, Railway, Render)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Railway: link your Postgres plugin → Variables → reference DATABASE_URL on the web service.
# Also set JWT_SECRET (and SMTP_* if you use password reset email).

# Password reset email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM=your-email@gmail.com
FRONTEND_URL=http://localhost:3000

# Policy Assistant chatbot (Claude). Without this key the bot shows a friendly fallback message.
ANTHROPIC_API_KEY=

# ESSL/ZKTeco attendance device
# IMPORTANT: Vercel cannot reach office LAN IPs (192.168.x.x). Use essl-bridge on an office PC (see npm run essl:bridge).
ESSL_ENABLED=true
ESSL_DEVICE_IP=192.168.0.254
ESSL_DEVICE_PORT=4370
ESSL_DEVICE_TIMEOUT_MS=30000
ESSL_INPORT=5200
# node-zklib handles eSSL comm key auth better than zklib-js
ESSL_SDK=node-zklib
# Numeric Comm Key from device Menu → Comm → PC Connection (0 if disabled)
ESSL_COMM_KEY=0
# Prefer TCP only — UDP often fails on Windows (EADDRINUSE / timeout)
ESSL_TCP_ONLY=true
ESSL_PREFER_UDP=false
# Poll every 5 minutes (300000 ms). Every 2 hours = 7200000
ESSL_POLL_INTERVAL_MS=300000
# How many past days to import on each sync (14 is safe for first run)
ESSL_LOOKBACK_DAYS=14
ESSL_DAY_START=09:30
ESSL_DAY_END=23:59

# Bridge script (office PC → Vercel): same key on bridge .env and Vercel env vars
HRMS_API_URL=https://your-app.vercel.app
# local = write to DATABASE_URL on office PC | remote = push to HRMS_API_URL (use with Vercel)
ESSL_BRIDGE_MODE=remote
